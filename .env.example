# === LLM provider configuration ===
# Choose one: claude | openai | ollama | mock
LLM_PROVIDER=claude

# Anthropic Claude (recommended)
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI (alternative)
OPENAI_API_KEY=sk-...

# Ollama (local, for offline / privacy-sensitive deployments)
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3.1:8b

# === Vector store ===
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=eshop_code
EMBEDDING_MODEL=all-MiniLM-L6-v2

# === Mocks ===
JIRA_MOCK_URL=http://jira-mock:3100
NOTIFICATION_MOCK_URL=http://notification-mock:3200

# === Observability (Phase 10) ===
LANGFUSE_PUBLIC_KEY=pk-lf-upstream-public
LANGFUSE_SECRET_KEY=sk-lf-upstream-secret
LANGFUSE_HOST=http://langfuse-web:3000

# === UI service (browser-facing links) ===
UI_AGENT_URL=http://host.docker.internal:8000
JIRA_MOCK_URL_EXTERNAL=http://localhost:3100
NOTIFICATION_MOCK_URL_EXTERNAL=http://localhost:3200
LANGFUSE_URL_EXTERNAL=http://localhost:3001

# === Persistence ===
CHECKPOINT_DB_PATH=/app/data/checkpoints/upstream.sqlite
