# ===========================================================================
# Upstream — Environment Configuration
# Copy this file to .env and fill in the values you need.
# Most values have sensible defaults; you only NEED to set ONE LLM API key.
# ===========================================================================

# === LLM provider ===
# Pick one: claude | openai | ollama | mock
# - claude: best quality (recommended)
# - openai: cloud alternative
# - ollama: local model, for air-gapped or privacy-sensitive deployments
# - mock: no LLM call (for testing)
LLM_PROVIDER=claude

# Anthropic API key (required if LLM_PROVIDER=claude)
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI API key (required if LLM_PROVIDER=openai)
OPENAI_API_KEY=sk-...

# Ollama model (only used if LLM_PROVIDER=ollama; pulled automatically on first use)
# Add the `--profile ollama` flag to docker compose to enable the Ollama service.
OLLAMA_MODEL=llama3.1:8b

# === Embedding provider for the indexer ===
# Pick one: local | openai
# - local: uses all-MiniLM-L6-v2 (no API key needed, slightly lower quality)
# - openai: uses text-embedding-3-small (requires OPENAI_API_KEY)
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=all-MiniLM-L6-v2
QDRANT_COLLECTION=eshop_code

# === Langfuse observability ===
# Pre-seeded credentials match the LANGFUSE_INIT_* values in docker-compose.yml.
# In production you would generate fresh keys via the Langfuse UI.
LANGFUSE_PUBLIC_KEY=pk-lf-upstream-public
LANGFUSE_SECRET_KEY=sk-lf-upstream-secret
